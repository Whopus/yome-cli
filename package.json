{
  "name": "yome",
  "version": "0.1.0",
  "description": "Yome CLI — AI coding agent",
  "type": "module",
  "bin": {
    "yome": "./bin/yome.mjs"
  },
  "scripts": {
    "build": "bun build src/index.tsx --outdir dist --target bun --external react --external ink --external ink-text-input",
    "dev": "bun --watch src/index.tsx",
    "start": "bun bin/yome.mjs",
    "compile": "bun build src/index.tsx --compile --outfile yome"
  },
  "dependencies": {
    "fast-glob": "^3.3.2",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "marked": "^17.0.6",
    "meow": "^13.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "typescript": "^5.5.0"
  }
}
