{
  "name": "@poping/yome",
  "version": "0.0.3",
  "description": "Yome Agent — the open-source Empower Kernel CLI",
  "type": "module",
  "bin": {
    "yome": "bin/yome.js"
  },
  "files": [
    "bin",
    "dist",
    "NOTICE"
  ],
  "homepage": "https://github.com/Whopus/yome-agent",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Whopus/yome-agent.git"
  },
  "bugs": {
    "url": "https://github.com/Whopus/yome-agent/issues"
  },
  "scripts": {
    "build": "tsc",
    "build:native": "cd native/calwatch && swift build -c release && cp .build/release/yome-calwatch ../../bin/yome-calwatch",
    "build:all": "npm run build && npm run build:native",
    "dev": "bun --watch src/index.tsx",
    "start": "node bin/yome.js",
    "test": "bun test src/config.test.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cli",
    "ai",
    "coding",
    "agent",
    "yome"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "chokidar": "^3.6.0",
    "fast-glob": "^3.3.2",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "marked": "^17.0.6",
    "meow": "^13.0.0",
    "node-cron": "^3.0.3",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.3",
    "typescript": "^5.5.0"
  }
}
